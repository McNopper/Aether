<?xml version="1.0"?>
<materialx version="1.39" colorspace="lin_rec709">
  <surfacematerial name="PolishedCopper" type="material">
    <input name="surfaceshader" type="surfaceshader" nodename="polished_copper_srf" />
  </surfacematerial>
  <open_pbr_surface name="polished_copper_srf" type="surfaceshader">
    <input name="base_color" type="color3" value="0.955, 0.638, 0.538" />
    <input name="base_metalness" type="float" value="1.0" />
    <input name="specular_roughness" type="float" value="0.1" />
    <input name="specular_roughness_anisotropy" type="float" value="0.0" />
  </open_pbr_surface>
</materialx>
