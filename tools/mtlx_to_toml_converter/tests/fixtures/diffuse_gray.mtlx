<?xml version="1.0"?>
<materialx version="1.39" colorspace="lin_rec709">
  <surfacematerial name="DiffuseGray" type="material">
    <input name="surfaceshader" type="surfaceshader" nodename="diffuse_gray_srf" />
  </surfacematerial>
  <open_pbr_surface name="diffuse_gray_srf" type="surfaceshader">
    <input name="base_weight" type="float" value="1.0" />
    <input name="base_color" type="color3" value="0.6, 0.6, 0.6" />
    <input name="specular_roughness" type="float" value="0.5" />
  </open_pbr_surface>
</materialx>
