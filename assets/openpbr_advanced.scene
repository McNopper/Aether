# OpenPBR Advanced Transmission / Subsurface Showcase — Hyperion demo
# Demonstrates transmission_scatter, dispersion, thin-walled, and subsurface
# scatter-anisotropy — 6 spheres. Materials from openpbr_advanced.mtlx.

mtllib openpbr_advanced.mtlx
mtllib floor.mtlx

env_map       relax_inn_seaview_suite_4k.exr
env_unit_nits 10000
spp           256
max_depth     16
ev100         12

camera
  translate  0.0  2.0  -8.0
  look_at    0.0  0.70  0.0
  vfov       50

# Ground plane
box 10.0 0.1 8.0
  translate  0.0 -0.05  0.0
  usemtl NeutralFloor

# ── Row 0  z = -1.0 ───────────────────────────────────────────────────────────
sphere 0.70
  translate -2.5  0.70  -1.0
  usemtl MilkyScatter

sphere 0.70
  translate  0.0  0.70  -1.0
  usemtl DispersiveDiamond

sphere 0.70
  translate  2.5  0.70  -1.0
  usemtl HoneyScatter

# ── Row 1  z = +1.5 ───────────────────────────────────────────────────────────
sphere 0.70
  translate -2.5  0.70  1.5
  usemtl ThinGlassSheet

sphere 0.70
  translate  0.0  0.70  1.5
  usemtl TranslucentLeaf

sphere 0.70
  translate  2.5  0.70  1.5
  usemtl WaxySubsurface
