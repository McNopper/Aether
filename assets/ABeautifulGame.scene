# ABeautifulGame — chess set (Academy Software Foundation, MaterialX sample asset)
# converted to Hyperion OBJ + OpenPBR .mtlx.  Validates the full bindless texture path:
# base_color (sRGB), ORM (occlusion/roughness/metalness) and tangent-space normal
# maps on 15 materials, lit purely by an HDR environment (IBL).

mtllib ABeautifulGame/ABeautifulGame.mtlx

env_map       meadow_2_4k.exr
env_unit_nits 10000
tonemapper    agx
spp           256
max_depth     12
ev100         11

camera
  translate  0.45 0.40 0.55
  look_at    0.0  0.04 0.0
  vfov       42

instance ABeautifulGame/ABeautifulGame.obj
  material King_Black      King_Black
  material King_White      King_White
  material Queen_Black     Queen_Black
  material Queen_White     Queen_White
  material Chessboard      Chessboard
  material Pawn_Top_White  Pawn_Top_White
  material Pawn_Body_White Pawn_Body_White
  material Pawn_Top_Black  Pawn_Top_Black
  material Pawn_Body_Black Pawn_Body_Black
  material Castle_Black    Castle_Black
  material Castle_White    Castle_White
  material Knight_Black    Knight_Black
  material Knight_White    Knight_White
  material Bishop_Black    Bishop_Black
  material Bishop_White    Bishop_White
