# OpenPBR Specular Lobe Showcase — Hyperion demo
# 15 spheres in 3 rows × 5, lit by IBL panorama.
# Tests specular_roughness (row 0), specular_ior (row 1),
# specular_roughness_anisotropy on brushed metal (row 2).
# Materials from openpbr_specular.mtlx.

mtllib openpbr_specular.mtlx
mtllib floor.mtlx

env_map       meadow_2_4k.exr
env_unit_nits 10000
spp           128
max_depth     8
ev100         12

camera
  translate  0.0  2.5  -10.0
  look_at    0.0  0.70   1.0
  vfov       52

# Ground plane
box 12.0 0.1 10.0
  translate  0.0 -0.05  1.0
  usemtl NeutralFloor

# ── Row 0  z = -2.0  specular_roughness sweep ───────────────────────────────
sphere 0.70
  translate -5.0  0.70  -2.0
  usemtl SpecRough_0

sphere 0.70
  translate -2.5  0.70  -2.0
  usemtl SpecRough_10

sphere 0.70
  translate  0.0  0.70  -2.0
  usemtl SpecRough_25

sphere 0.70
  translate  2.5  0.70  -2.0
  usemtl SpecRough_50

sphere 0.70
  translate  5.0  0.70  -2.0
  usemtl SpecRough_100

# ── Row 1  z = +0.5  specular_ior sweep ────────────────────────────────────
sphere 0.70
  translate -5.0  0.70  0.5
  usemtl SpecIOR_1_2

sphere 0.70
  translate -2.5  0.70  0.5
  usemtl SpecIOR_1_4

sphere 0.70
  translate  0.0  0.70  0.5
  usemtl SpecIOR_1_6

sphere 0.70
  translate  2.5  0.70  0.5
  usemtl SpecIOR_2_0

sphere 0.70
  translate  5.0  0.70  0.5
  usemtl SpecIOR_2_5

# ── Row 2  z = +3.0  specular_roughness_anisotropy sweep ────────────────────
sphere 0.70
  translate -5.0  0.70  3.0
  usemtl Aniso_0

sphere 0.70
  translate -2.5  0.70  3.0
  usemtl Aniso_25

sphere 0.70
  translate  0.0  0.70  3.0
  usemtl Aniso_50

sphere 0.70
  translate  2.5  0.70  3.0
  usemtl Aniso_75

sphere 0.70
  translate  5.0  0.70  3.0
  usemtl Aniso_95
