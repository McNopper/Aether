# OpenPBR Fuzz / Sheen Layer Showcase — Hyperion demo
# 15 spheres in 3 rows × 5, lit by IBL panorama.
# Tests fuzz_weight (row 0), fuzz_roughness (row 1), named fabric archetypes (row 2).
# Materials from openpbr_fuzz.mtlx.

mtllib openpbr_fuzz.mtlx
mtllib floor.mtlx

env_map       meadow_2_4k.exr
env_unit_nits 10000
spp           64
max_depth     8
ev100         12

camera
  translate  0.0  2.5  -10.0
  look_at    0.0  0.70   1.0
  vfov       52

# Ground plane
box 12.0 0.1 10.0
  translate  0.0 -0.05  1.0
  usemtl NeutralFloor

# ── Row 0  z = -2.0  fuzz_weight sweep ──────────────────────────────────────
sphere 0.70
  translate -5.0  0.70  -2.0
  usemtl FuzzWeight_0

sphere 0.70
  translate -2.5  0.70  -2.0
  usemtl FuzzWeight_20

sphere 0.70
  translate  0.0  0.70  -2.0
  usemtl FuzzWeight_40

sphere 0.70
  translate  2.5  0.70  -2.0
  usemtl FuzzWeight_70

sphere 0.70
  translate  5.0  0.70  -2.0
  usemtl FuzzWeight_100

# ── Row 1  z = +0.5  fuzz_roughness sweep ───────────────────────────────────
sphere 0.70
  translate -5.0  0.70  0.5
  usemtl FuzzRough_10

sphere 0.70
  translate -2.5  0.70  0.5
  usemtl FuzzRough_25

sphere 0.70
  translate  0.0  0.70  0.5
  usemtl FuzzRough_50

sphere 0.70
  translate  2.5  0.70  0.5
  usemtl FuzzRough_75

sphere 0.70
  translate  5.0  0.70  0.5
  usemtl FuzzRough_100

# ── Row 2  z = +3.0  named fabric archetypes ────────────────────────────────
sphere 0.70
  translate -5.0  0.70  3.0
  usemtl Cotton

sphere 0.70
  translate -2.5  0.70  3.0
  usemtl Silk

sphere 0.70
  translate  0.0  0.70  3.0
  usemtl Suede

sphere 0.70
  translate  2.5  0.70  3.0
  usemtl Denim

sphere 0.70
  translate  5.0  0.70  3.0
  usemtl Velour
