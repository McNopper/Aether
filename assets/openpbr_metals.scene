# OpenPBR Metals Showcase — Hyperion demo
# 20 metal spheres in 4 rows × 5, lit by IBL panorama.
# Spacing 2.5 (radius 0.70, gap 1.10) ensures inter-sphere reflections are visible.
# Materials from openpbr_metals.mtlx (F0/F82 conductor model).

mtllib openpbr_metals.mtlx
mtllib floor.mtlx

env_map       meadow_2_4k.exr
env_unit_nits 10000
spp           64
max_depth     6
ev100         12

camera
  translate  0.0  3.0  -12.0
  look_at    0.0  0.7    0.0
  vfov       52

# Ground plane
box 12.0 0.1 12.0
  translate  0.0 -0.05  0.0
  usemtl NeutralFloor

# ── Row 0  z = -3.75 ──────────────────────────────────────────────────────────
sphere 0.70
  translate -5.0  0.70  -3.75
  usemtl Copper

sphere 0.70
  translate -2.5  0.70  -3.75
  usemtl Gold

sphere 0.70
  translate  0.0  0.70  -3.75
  usemtl Silver

sphere 0.70
  translate  2.5  0.70  -3.75
  usemtl Platinum

sphere 0.70
  translate  5.0  0.70  -3.75
  usemtl Iridium

# ── Row 1  z = -1.25 ──────────────────────────────────────────────────────────
sphere 0.70
  translate -5.0  0.70  -1.25
  usemtl AluminumBrushed

sphere 0.70
  translate -2.5  0.70  -1.25
  usemtl Iron

sphere 0.70
  translate  0.0  0.70  -1.25
  usemtl Titanium

sphere 0.70
  translate  2.5  0.70  -1.25
  usemtl StainlessSteel

sphere 0.70
  translate  5.0  0.70  -1.25
  usemtl Brass

# ── Row 2  z = +1.25 ──────────────────────────────────────────────────────────
sphere 0.70
  translate -5.0  0.70  1.25
  usemtl Chromium

sphere 0.70
  translate -2.5  0.70  1.25
  usemtl Cobalt

sphere 0.70
  translate  0.0  0.70  1.25
  usemtl Nickel

sphere 0.70
  translate  2.5  0.70  1.25
  usemtl Zinc

sphere 0.70
  translate  5.0  0.70  1.25
  usemtl Palladium

# ── Row 3  z = +3.75 ──────────────────────────────────────────────────────────
sphere 0.70
  translate -5.0  0.70  3.75
  usemtl Tungsten

sphere 0.70
  translate -2.5  0.70  3.75
  usemtl Lead

sphere 0.70
  translate  0.0  0.70  3.75
  usemtl Molybdenum

sphere 0.70
  translate  2.5  0.70  3.75
  usemtl Vanadium

sphere 0.70
  translate  5.0  0.70  3.75
  usemtl Silicon
