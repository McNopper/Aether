# dragon_teapot.scene — a glazed-ceramic teapot beside a gem-like volumetric
# dragon, lit entirely by an HDR environment (IBL) via relax_inn_seaview_suite_4k.exr.
# Demonstrates OpenPBR coat (ceramic glaze) and transmission with Beer-Lambert
# absorption (gem) under image-based lighting.

mtllib dragon_teapot.mtlx

env_map       relax_inn_seaview_suite_4k.exr
env_unit_nits 10000
tonemapper    agx
spp           256
max_depth     16
ev100         12

camera
  translate  0.5  3.2 -9.5
  look_at    0.0  0.7  0.0
  vfov       50

# Studio pedestal (top face at y = 0) — kept small so the HDR environment
# remains visible around and behind the objects.
box 6.0 0.1 3.0
  translate 0.0 -0.1 0.0
  usemtl Floor

# Ceramic teapot — scaled to ~1.6 units tall, placed left of centre.
instance teapot.obj
  usemtl Ceramic
  scale     0.5 0.5 0.5
  translate -2.2 0.0 0.0

# Gem dragon — doubled in size and lifted so it rests on the floor
# (model min y = -0.583 * 2 = -1.166), placed right.
instance dragon.obj
  usemtl Gem
  scale     2.0 2.0 2.0
  translate 1.8 1.166 0.0
  rotate_y  35
